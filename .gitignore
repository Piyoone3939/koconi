# ========================================
# 🌐 共通・OS設定
# ========================================
.DS_Store
Thumbs.db
*.log

# ========================================
# 🎮 Unity (apps/game)
# ========================================
# Unityの一時フォルダやビルド生成物を除外
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
# 特定のパス指定にする場合: apps/game/Library/ などでも可

# Visual Studio / JetBrains 生成物
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.slnx

# ========================================
# 🧱 Backend & Services (Node.js / Python)
# ========================================
# パスが変わっても効くように **/ を使用
**/node_modules/
**/npm-debug.log*
**/yarn-error.log*
**/.env
**/.env.*

# Prisma
**/prisma/*.db
**/prisma/migrations/

# Python (AI service)
**/__pycache__/
**/*.py[cod]
**/venv/
**/.venv/

# ========================================
# ⚛️ Frontend (Next.js / React)
# ========================================
**/.next/
**/out/
**/dist/
**/build/
**/.vercel/
**/coverage/